<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xmlns="UnityEngine.UIElements" editor-extension-mode="True">
    <ui:VisualElement class="foldout-container" style="flex-direction: column;">
        <ui:VisualElement name="credentials-toggle-container" style="flex-grow: 1; flex-direction: row;">
            <ui:Toggle label="Sign Build" name="credentials-toggle" tooltip="Whether Build Automation should sign the resulting build artifact or not. This is required for iOS, Android, and UWP builds."/>
            <ui:Button name="sign-build-info-button" style="padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 2; background-color: rgba(188, 188, 188, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;" />
        </ui:VisualElement>
        <ui:VisualElement name="credentials-container" style="flex-grow: 1; flex-direction: row;">
            <ui:DropdownField name="credentials-dropdown" label="Credentials" tooltip="The credentials used to sign your build. These can be configured in the DevOps Dashboard." class="foldout-config-dropdown" style="flex-grow: 1; flex-direction: row;"/>
            <ui:Button name="new-credentials-button" text="New" tooltip="Create new signing credentials in the DevOps dashboard" class="foldout-button"/>
            <ui:Button name="refresh-credentials-button" text="Refresh List" tooltip="Re-fetch your list of credentials from the Build Automation service" class="foldout-button" style="margin-left: 0;"/>
        </ui:VisualElement>
        <ui:HelpBox text="{credentials} will expire on 01/01/2024" message-type="Info" name="credentials-help-box" style="display: none;"/>
    </ui:VisualElement>
</ui:UXML>
